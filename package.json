{
  "name": "temp_vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run hermes:idle\" \"npm run api:start\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "hermes:idle": "npx tsx scripts/goal-orchestrator.ts",
    "api:start": "npx tsx scripts/start-api.ts",
    "daemon:start": "npx pm2 start ecosystem.config.cjs",
    "daemon:stop": "npx pm2 stop asclepius-orchestrator",
    "daemon:logs": "npx pm2 logs asclepius-orchestrator",
    "daemon:status": "npx pm2 status",
    "widget": "electron widget.cjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "pm2": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}